{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["es2020", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": ".qa-dist",
    "rootDir": "."
  },
  "include": [
    "tests/**/*.ts",
    "src/lib/session-checkin-token.ts",
    "src/lib/course-lifecycle-shared.ts",
    "src/lib/course-subscription-checkout.ts",
    "src/lib/profile-image-upload.ts",
    "src/lib/site-url.ts",
    "src/lib/stripe/phone-normalization.ts"
  ]
}
